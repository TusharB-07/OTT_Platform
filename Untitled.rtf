\f0\b\fs36 \cf0 \strokec2 13. Flask Blueprint Example \'97 Admin Analytics\
\pard\pardeftab720\partightenfactor0

\f3\b0\fs26 \cf0 # app/admin/routes_analytics.py\
from flask import Blueprint, jsonify\
from flask_jwt_extended import jwt_required\
from app.db import get_db\
from app.utils import admin_required   # custom decorator\
\
admin_analytics = Blueprint('admin_analytics', __name__, url_prefix='/api/admin/analytics')\
\
@admin_analytics.get('/kpis')\
@jwt_required()\
@admin_required\
def kpis():\
    db = get_db()\
    cursor = db.cursor(dictionary=True)\
\
    cursor.execute("SELECT COUNT(*) AS total_users FROM Users")\
    users = cursor.fetchone()['total_users']\
\
    cursor.execute("SELECT COUNT(*) AS active_subs FROM Subscription WHERE Status = 'Active'")\
    subs = cursor.fetchone()['active_subs']\
\
    cursor.execute("SELECT COALESCE(SUM(Amount), 0) AS total_revenue FROM Payment")\
    revenue = cursor.fetchone()['total_revenue']\
\
    return jsonify(\{"total_users": users, "active_subscriptions": subs, "total_revenue": float(revenue)\})\
\
@admin_analytics.get('/top-content')\
@jwt_required()\
@admin_required\
def top_content():\
    db = get_db()\
    cursor = db.cursor(dictionary=True)\
    cursor.execute("""\
        SELECT c.ContentID, c.Title, c.Content_Type, COUNT(w.WatchID) AS watch_count\
        FROM Content c\
        LEFT JOIN Watches w ON c.ContentID = w.ContentID\
        GROUP BY c.ContentID\
        ORDER BY watch_count DESC\
        LIMIT 10\
    """)\
    return jsonify(cursor.fetchall())\
\
@admin_analytics.get('/revenue-by-method')\
@jwt_required()\
@admin_required\
def revenue_by_method():\
    db = get_db()\
    cursor = db.cursor(dictionary=True)\
    cursor.execute("""\
        SELECT Method, COUNT(*) AS txn_count, SUM(Amount) AS total\
        FROM Payment\
        GROUP BY Method\
    """)\
    return jsonify(cursor.fetchall())\
\
@admin_analytics.get('/signups-monthly')\
@jwt_required()\
@admin_required\
def signups_monthly():\
    db = get_db()\
    cursor = db.cursor(dictionary=True)\
    cursor.execute("""\
        SELECT DATE_FORMAT(created_at, '%Y-%m') AS month, COUNT(*) AS signups\
        FROM Users\
        WHERE created_at >= DATE_SUB(CURDATE(), INTERVAL 12 MONTH)\
        GROUP BY month\
        ORDER BY month\
    """)\
    return jsonify(cursor.fetchall())\
