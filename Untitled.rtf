\f3\b0\fs26 \cf0 -- Derived Age\
CREATE VIEW v_user_age AS\
SELECT UserID, FirstName, LastName, DOB,\
       TIMESTAMPDIFF(YEAR, DOB, CURDATE()) AS Age\
FROM Users;\
\
-- Average content rating\
CREATE VIEW v_content_rating AS\
SELECT c.ContentID, c.Title,\
       ROUND(AVG(r.Rev_Score), 1) AS Avg_Rating,\
       COUNT(r.ReviewID) AS Review_Count\
FROM Content c\
LEFT JOIN Watches w ON c.ContentID = w.ContentID\
LEFT JOIN Review r ON w.WatchID = r.WatchID\
GROUP BY c.ContentID;\
\
-- Active subscriptions\
CREATE VIEW v_active_subscriptions AS\
SELECT s.UserID, u.FirstName, p.Plan_Name, s.Start_Date, s.End_Date, s.Status\
FROM Subscription s\
JOIN Users u ON s.UserID = u.UserID\
JOIN Plan p ON s.PlanID = p.PlanID\
WHERE s.Status = 'Active';\
